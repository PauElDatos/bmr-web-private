# Copia este archivo como automation/env/daily-export.env
# No subas daily-export.env al repositorio.

# Credenciales de exportación
ENV_FILE=exporter/.env.local

# Destino JSON usado por la web
OUT_DIR=web/data

# Límites de exportación. 0 = todos en los campos soportados.
MAX_POINTS=8000
MAX_INDICATORS=0
MAX_ASSETS=500
MAX_SERIES=0
MAX_CRYPTO=100
MAX_RUNS=150

# Git / publicación
BRANCH=main
GIT_REMOTE=origin
COMMIT_PREFIX="data: update BMR web snapshot"

# Python / virtualenv
PYTHON_BIN=python3
VENV_DIR=.venv-exporter

# Logs y lock
LOG_DIR=automation/logs
LOCK_FILE=/tmp/bmr-web-export.lock

# Comandos opcionales antes/después del exportador.
# Ejemplo para ejecutar cadenas Docker antes de exportar:
# BMR_PRE_EXPORT_COMMAND="cd /opt/bmr-docker && ./scripts/run_etl.sh && ./scripts/run_ml.sh"
BMR_PRE_EXPORT_COMMAND=
BMR_POST_EXPORT_COMMAND=

# Fase 6: publicación opcional de JSON reales en Cloudflare R2 privado.
# Si lo activas, el Worker leerá /data/* desde el binding PRIVATE_DATA_BUCKET.
BMR_PUBLISH_R2=0
BMR_R2_BUCKET=bmr-private-data
BMR_R2_PREFIX=data
