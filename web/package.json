{
  "name": "bmr-web-private-phase5",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "BMR web estática — Fase 5 con automatización diaria, validación y publicación GitHub Pages.",
  "scripts": {
    "dev": "python3 -m http.server 8080",
    "dev:win": "py -m http.server 8080",
    "validate:data": "python3 ../exporter/validate_web_json.py --data-dir data",
    "check:js": "find src -name \"*.js\" -print0 | xargs -0 -n1 node --check"
  }
}