# BMR Web Exporter - ejemplo de configuración
# Copia este archivo como .env.local o reutiliza el .env del proyecto Docker.
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=bmr
DB_USER=api
DB_PASS=CAMBIAR

# Alternativamente también se aceptan BMR_DB_*
# BMR_DB_HOST=127.0.0.1
# BMR_DB_PORT=3307
# BMR_DB_NAME=bmr
# BMR_DB_USER=api
# BMR_DB_PASS=CAMBIAR
